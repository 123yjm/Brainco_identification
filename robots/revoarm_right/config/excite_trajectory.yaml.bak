# Excitation Trajectory Optimization — revoarm_right
# robot / kinematic_params / output_trajectory 由入口函数自动推导。

fourier_order: 5
sampling_time: 10.0
sampling_frequency: 10
trajectory_frequency: 100

q_init: [-1.5, 0.15, 0.0, 0.0, -1.725, 0.0, 0.0]
q_min: [-2.5, -0.15, -2.09, -0.3, -4.0, -0.54, -1.57]
q_max: [ 0.7,  1.65,  2.09,  2.21, 0.55,  0.54,  1.57]

q_dot_max:  [1.396, 1.396, 1.396, 1.396, 1.396, 1.396, 1.396]
q_ddot_max: [4.189, 4.189, 4.189, 4.189, 4.189, 4.189, 4.189]

multi_start_count: 8
max_iterations: 15000
ftol_rel: 1.0e-10

# --- 目标函数配置 (可选, 默认 d_optimal) ---
objective_type: "cond_w_base"   # d_optimal | cond_w_base | hybrid
param_flags: "none"             # none (=仅惯性参数) | all
# cond_weight: 1.0              # hybrid 模式下 cond 权重
# dopt_weight: 1.0              # hybrid 模式下 D-optimal 权重
# qrcp_tol: 1.0                 # QRCP 秩判定阈值乘数
